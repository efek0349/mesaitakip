<?xml version="1.0" encoding="utf-8"?>
<!-- Klasik Win95 "kabarık" (raised) buton/panel kenarlığı:
     dış üst-sol beyaz highlight, dış alt-sağ koyu gölge,
     iç alt-sağ siyah çizgi, iç dolgu açık gri (#C0C0C0). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#808080" />
        </shape>
    </item>
    <item
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#000000" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#C0C0C0" />
        </shape>
    </item>
</layer-list>
