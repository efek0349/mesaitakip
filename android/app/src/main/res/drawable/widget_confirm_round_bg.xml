<?xml version="1.0" encoding="utf-8"?>
<!-- Modern "kabarık" (raised) Ekle butonu: parlak üst - koyu alt degrade,
     gerçek elevation (bkz. layout) ile birlikte belirgin bir 3D buton
     hissi verir. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="10dp" />
    <gradient
        android:angle="270"
        android:startColor="#5B93F7"
        android:centerColor="#3B82F6"
        android:endColor="#2563EB" />
    <stroke
        android:width="1dp"
        android:color="#2354C9" />
</shape>
