<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:background="@drawable/win95_flat_outer_bg"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- SAAT grubu -->
    <Button
        android:id="@+id/btn_hours_dec"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/win95_raised_bg"
        android:text="−"
        android:textColor="#000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

    <TextView
        android:id="@+id/text_hours_value"
        android:layout_width="32dp"
        android:layout_height="28dp"
        android:layout_marginStart="4dp"
        android:gravity="center"
        android:background="@drawable/win95_sunken_bg"
        android:text="2"
        android:textColor="#000000"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="3dp"
        android:layout_marginEnd="5dp"
        android:text="sa"
        android:textColor="#000000"
        android:textSize="8sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <Button
        android:id="@+id/btn_hours_inc"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/win95_raised_bg"
        android:text="+"
        android:textColor="#000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

    <!-- ayırıcı -->
    <TextView
        android:layout_width="2dp"
        android:layout_height="26dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:text=""
        android:background="#808080" />

    <!-- DAKİKA grubu -->
    <Button
        android:id="@+id/btn_minutes_dec"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/win95_raised_bg"
        android:text="−"
        android:textColor="#000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

    <TextView
        android:id="@+id/text_minutes_value"
        android:layout_width="32dp"
        android:layout_height="28dp"
        android:layout_marginStart="4dp"
        android:gravity="center"
        android:background="@drawable/win95_sunken_bg"
        android:text="00"
        android:textColor="#000000"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="3dp"
        android:layout_marginEnd="5dp"
        android:text="dk"
        android:textColor="#000000"
        android:textSize="8sp"
        android:textStyle="bold"
        android:fontFamily="monospace" />

    <Button
        android:id="@+id/btn_minutes_inc"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/win95_raised_bg"
        android:text="+"
        android:textColor="#000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

    <!-- Ekle butonu -->
    <Button
        android:id="@+id/btn_confirm"
        android:layout_width="46dp"
        android:layout_height="30dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/win95_raised_bg"
        android:text="Ekle"
        android:textColor="#000000"
        android:textAllCaps="false"
        android:textSize="10sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

</LinearLayout>
