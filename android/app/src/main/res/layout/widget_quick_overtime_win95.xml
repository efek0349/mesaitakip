<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#D8D8D8"
    android:paddingStart="1dp"
    android:paddingEnd="1dp"
    android:paddingTop="0dp"
    android:paddingBottom="0dp">

    <!-- Üst satır: saat/dakika stepper'ları + Ekle butonu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- SAAT grubu -->
        <Button
            android:id="@+id/btn_hours_dec"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/win95_raised_bg"
            android:text="−"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/text_hours_value"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:background="@drawable/win95_sunken_bg"
            android:text="2"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="5dp"
            android:text="sa"
            android:textColor="#000000"
            android:textSize="8sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btn_hours_inc"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/win95_raised_bg"
            android:text="+"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <!-- ayırıcı -->
        <TextView
            android:layout_width="2dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:text=""
            android:background="#808080" />

        <!-- DAKİKA grubu -->
        <Button
            android:id="@+id/btn_minutes_dec"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/win95_raised_bg"
            android:text="−"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/text_minutes_value"
            android:layout_width="36dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:background="@drawable/win95_sunken_bg"
            android:text="00"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="5dp"
            android:text="dk"
            android:textColor="#000000"
            android:textSize="8sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btn_minutes_inc"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/win95_raised_bg"
            android:text="+"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <!-- Ekle butonu -->
        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="40dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/win95_raised_bg"
            android:text="Ekle"
            android:textColor="#000000"
            android:textAllCaps="false"
            android:textSize="9sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- alt ayırıcı çizgi -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="5dp"
        android:text=""
        android:background="#808080" />

    <!-- Alt satır: tek satırda üç değer — Bu Ay / Net Mesai / Maaş -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BU AY"
            android:textColor="#666666"
            android:textSize="7sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/text_widget_summary_hours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0 s"
            android:textColor="#000000"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="🕐"
            android:textSize="8sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="|"
            android:textColor="#808080"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NET MESAİ"
            android:textColor="#666666"
            android:textSize="7sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/text_widget_summary_overtime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="₺0"
            android:textColor="#000080"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="|"
            android:textColor="#808080"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NET MAAŞ"
            android:textColor="#666666"
            android:textSize="7sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/text_widget_summary_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="₺0"
            android:textColor="#006400"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

    </LinearLayout>

</LinearLayout>
