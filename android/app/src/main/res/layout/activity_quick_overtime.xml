<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/quick_overtime_card_bg"
    android:padding="20dp"
    android:elevation="8dp">

    <TextView
        android:id="@+id/quick_overtime_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/quick_overtime_title"
        android:textColor="#111827"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/quick_overtime_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="16dp"
        android:textColor="#6B7280"
        android:textSize="13sp"
        tools:text="10 Temmuz 2026" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- SAAT çarkı -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/quick_overtime_hours_label"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="132dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/wheel_highlight_bg" />

                <ScrollView
                    android:id="@+id/hours_wheel_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/hours_wheel_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_gravity="top"
                    android:background="@drawable/wheel_fade_top" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/wheel_fade_bottom" />
            </FrameLayout>
        </LinearLayout>

        <!-- DAKİKA çarkı -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/quick_overtime_minutes_label"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="132dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/wheel_highlight_bg" />

                <ScrollView
                    android:id="@+id/minutes_wheel_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/minutes_wheel_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_gravity="top"
                    android:background="@drawable/wheel_fade_top" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/wheel_fade_bottom" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/quick_overtime_cancel_button"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/quick_overtime_button_secondary_bg"
            android:text="@string/quick_overtime_cancel"
            android:textColor="#111827"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/quick_overtime_add_button"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/quick_overtime_button_primary_bg"
            android:text="@string/quick_overtime_add"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
