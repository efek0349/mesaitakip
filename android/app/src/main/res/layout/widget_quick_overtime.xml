<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_flat_bg"
    android:paddingStart="1dp"
    android:paddingEnd="1dp"
    android:paddingTop="0dp"
    android:paddingBottom="0dp">

    <!-- Üst satır: saat/dakika stepper'ları + Ekle butonu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- SAAT grubu -->
        <Button
            android:id="@+id/btn_hours_dec"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_stepper_button_round_bg"
            android:text="−"
            android:textColor="#3B82F6"
            android:textSize="15sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="3dp"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/text_hours_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="1dp"
            android:gravity="center"
            android:text="2"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_marginTop="5dp"
            android:text="sa"
            android:textColor="#9CA3AF"
            android:textSize="9sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_hours_inc"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_stepper_button_round_bg"
            android:text="+"
            android:textColor="#3B82F6"
            android:textSize="15sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="3dp"
            android:stateListAnimator="@null" />

        <!-- ayırıcı -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:text=""
            android:background="#E5E7EB" />

        <!-- DAKİKA grubu -->
        <Button
            android:id="@+id/btn_minutes_dec"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_stepper_button_round_bg"
            android:text="−"
            android:textColor="#3B82F6"
            android:textSize="15sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="3dp"
            android:stateListAnimator="@null" />

        <TextView
            android:id="@+id/text_minutes_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="1dp"
            android:gravity="center"
            android:text="00"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_marginTop="5dp"
            android:text="dk"
            android:textColor="#9CA3AF"
            android:textSize="9sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_minutes_inc"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_stepper_button_round_bg"
            android:text="+"
            android:textColor="#3B82F6"
            android:textSize="15sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="3dp"
            android:stateListAnimator="@null" />

        <!-- Ekle butonu -->
        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_confirm_round_bg"
            android:text="Ekle"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:elevation="4dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- alt ayırıcı çizgi -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:text=""
        android:background="#F0F1F3" />

    <!-- Alt satır: tek satırda üç değer — Bu Ay / Net Mesai / Maaş -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BU AY"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <TextView
            android:id="@+id/text_widget_summary_hours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0 s"
            android:textColor="#111827"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="🕐"
            android:textSize="9sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:text="•"
            android:textColor="#E5E7EB"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NET MESAİ"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <TextView
            android:id="@+id/text_widget_summary_overtime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="₺0"
            android:textColor="#3B82F6"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:text="•"
            android:textColor="#E5E7EB"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NET MAAŞ"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <TextView
            android:id="@+id/text_widget_summary_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="₺0"
            android:textColor="#10B981"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
